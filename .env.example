# Radio FEM - Local environment template
# Copy to .env and fill with your real values.
# Do not commit .env.

# Google Play service account JSON path (relative to android/app/build.gradle.kts)
# Current Gradle config expects ../play-account.json, but you can keep this for scripts/CI.
PLAY_SERVICE_ACCOUNT_JSON_PATH=../play-account.json

# Android signing (used by Gradle env lookup)
RELEASE_STORE_FILE=radiofem-release.jks
RELEASE_STORE_PASSWORD=CHANGE_ME
RELEASE_KEY_ALIAS=CHANGE_ME
RELEASE_KEY_PASSWORD=CHANGE_ME

# Optional app overrides
RADIO_FEM_VERSION_NAME=1.0.18
RADIO_FEM_VERSION_CODE=10022
RADIO_FEM_PLAY_TRACK=beta
